extends ../layout

block content
    h1 Edit user
    form(action=`/users/${user.id}/edit`, method="post")
        label(for="name") Name:
            input(type="text", name="name", id="name", required, minlength="4", maxlength="128", value=user.name)
        br
        label(for="bio") Bio:
            textarea(name="bio", id="bio", value=user.bio)
        br
        button(type="submit") Save